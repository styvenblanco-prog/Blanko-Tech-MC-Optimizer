<?xml version="1.0" encoding="utf-8"?>
<!-- 
  BlankoTech MC Optimizer - Material Design 3 XML Reference Layout
  Este archivo se proporciona como referencia de diseño Material Design 3.
  La aplicación principal se renderiza usando Jetpack Compose en MainActivity.kt 
  para garantizar el mínimo consumo de RAM (<15MB) y máxima fluidez en el dispositivo objetivo.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    android:padding="24dp"
    tools:context=".MainActivity">

    <!-- Header Panel -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:layout_marginTop="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BLANKOTECH"
            android:textColor="@color/neon_cyan"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.4"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MC OPTIMIZER"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0 • Minecraft Bedrock Edition"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="6dp"/>
    </LinearLayout>

    <!-- Central Glowing Button Container -->
    <FrameLayout
        android:id="@+id/buttonContainer"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_centerInParent="true"
        android:layout_below="@id/headerLayout"
        android:layout_above="@+id/diagnosticsCard">

        <!-- Glowing Accent Border -->
        <View
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_gravity="center"
            android:background="@drawable/ic_launcher_background"
            android:alpha="0.2"/>

        <!-- Primary Action Button (Circle) -->
        <Button
            android:id="@+id/btnOptimize"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center"
            android:backgroundTint="@color/neon_green"
            android:text="@string/btn_optimize"
            android:textColor="@color/dark_background"
            android:textSize="14sp"
            android:textStyle="bold"
            android:elevation="8dp"/>
    </FrameLayout>

    <!-- Diagnostics Card (Glassmorphic look) -->
    <LinearLayout
        android:id="@+id/diagnosticsCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/footerLayout"
        android:layout_marginBottom="24dp"
        android:background="@color/dark_surface"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ESTADO DEL SISTEMA"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"/>

            <TextView
                android:id="@+id/tvSystemStatusPill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:text="ESTABLE"
                android:textColor="@color/neon_cyan"
                android:textSize="9sp"
                android:textStyle="bold"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"/>
        </RelativeLayout>

        <TextView
            android:id="@+id/tvStatusMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/status_idle"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="14dp"
            android:minLines="2"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#232D34"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"/>

        <!-- Atomic steps mock items -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ CPU WakeLock (Partial)"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ Limpieza de RAM (Procesos)"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ GameManager Performance API"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ Ejecutar Minecraft Bedrock"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- Technical Safety Footer -->
    <LinearLayout
        android:id="@+id/footerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#0D1E16"
            android:text="@string/no_root_banner"
            android:textColor="@color/neon_green"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Optimizaciones con APIs nativas de Android. Sin Root ni comandos su."
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:layout_marginTop="8dp"
            android:gravity="center"/>
    </LinearLayout>

</RelativeLayout>
